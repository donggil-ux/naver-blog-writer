# Server-side (Vercel Environment Variables)
# Naver Local Search API — for the store search list
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=

# Google Gemini — for title/body generation
GOOGLE_API_KEY=

# Google Places API (New) — for business hours / break time / closed days
GOOGLE_PLACES_API_KEY=

# Client-side (Vite) — optional
# Set to "1" during local development to bypass real APIs in StoreSearchInput.
VITE_USE_MOCK_STORE=
